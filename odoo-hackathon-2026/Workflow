name: Python CI Pipeline

on:
  push:
    branches: [ main ]
  pull_request:
    branches: [ main ]

jobs:
  build-and-test:
    runs-on: ubuntu-latest

    steps:
    - name: Check out repository
      uses: actions/checkout@v4

    - name: Set up Python 3.12
      uses: actions/setup-python@v5
      with:
        python-node-version: '3.12'

    - name: Install dependencies
      run: |
        python -m pip install --upgrade pip
        if [ -f odoo-hackathon-2026/requirements.txt ]; then pip install -r odoo-hackathon-2026/requirements.txt; fi

    - name: Syntax and Compile Checks
      run: |
        python -m py_compile odoo-hackathon-2026/app.py odoo-hackathon-2026/utils/*.py odoo-hackathon-2026/models/*.py odoo-hackathon-2026/pages/*.py

